# Vercel build exclusions - reduce deployment size
# Keep base installer as fallback, but exclude account-specific builds

# Allow base installers (fallback), exclude tokenized & other builds
public/tray/KuaminiSecurityClient-*.msi
public/tray/KuaminiSecurityClient-*.pkg
public/tray/KuaminiSecurityClient-*.tar.gz
public/tray/KuaminiSecurityClient-*.zip
public/tray/KuaminiSecurityClient-*-linux.tar.gz

# Allow base non-tokenized installer files as fallback
# These will be served when GitHub fetch fails
!public/tray/KuaminiSecurityClient-1.0.0.msi
!public/tray/KuaminiSecurityClient-1.0.0.pkg
!public/tray/KuaminiSecurityClient-linux.tar.gz

# Exclude build artifacts
agent-tray/dist/**
agent-tray/build/dist/**
.next/**
out/**

# Exclude development dependencies
node_modules/**
.venv/**
venv/**
__pycache__/**

# Exclude documentation and guides
*.md
docs/**
