# AWS / PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@aws-rds-endpoint:5432/threat_db
DATABASE_SSL=true
AWS_REGION=us-east-1

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://kuaminisystems.com/api/agent

# Session & Security
SESSION_SECRET=your-session-secret-here
INSTALLER_TOKEN_SECRET=your-secret-key-for-signed-tokens

# Email (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@kuaminisystems.com
CONTACT_INBOX_EMAIL=contact@kuaminisystems.com

# Development/Debug
DEBUG_REGISTRATION=false
NODE_ENV=production

# Optional: Error Monitoring (Sentry, LogRocket, etc.)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
