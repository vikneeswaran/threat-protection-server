<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Kuamini Security Client" Language="1033" Version="$(var.ProductVersion)"
           Manufacturer="Kuamini Systems" UpgradeCode="12345678-1234-1234-1234-123456789012">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Major upgrade logic -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize" />

    <!-- Define installation directories -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Kuamini Security Client">
          <Directory Id="INTERNALFOLDER" Name="_internal" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder" />
      <Directory Id="DesktopFolder" />
      <Directory Id="SystemFolder" />
    </Directory>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Kuamini Security Client" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentGroupRef Id="InternalFiles" />
      <ComponentRef Id="RegistryAutoStart" />
    </Feature>

    <!-- Main executable -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="87654321-1234-1234-1234-123456789012" Win64="yes">
        <File Id="KuaminiSecurityClient_exe" Name="KuaminiSecurityClient.exe"
              Source="$(var.SourceDir)\KuaminiSecurityClient.exe" KeyPath="yes" />
      </Component>
      <Component Id="RegistryAutoStart" Guid="99999999-8888-7777-6666-555555555555" Win64="yes">
        <RegistryValue Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="KuaminiSecurityClient"
                       Type="string"
                       Value="&quot;[INSTALLFOLDER]KuaminiSecurityClient.exe&quot;"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Copy registration token from source directory or search common locations (including subdirectories) -->
    <CustomAction Id="CopyRegistrationToken"
                  Directory="SystemFolder"
                  Execute="immediate"
                  ExeCommand="cmd.exe /c (if exist &quot;registration.token&quot; copy /Y &quot;registration.token&quot; &quot;[INSTALLFOLDER]registration.token&quot;) &amp;&amp; (if exist &quot;%USERPROFILE%\Downloads\registration.token&quot; copy /Y &quot;%USERPROFILE%\Downloads\registration.token&quot; &quot;[INSTALLFOLDER]registration.token&quot;) &amp;&amp; (for /D %%D in (&quot;%USERPROFILE%\Downloads\KuaminiSecurityClient-*&quot;) do @if exist &quot;%%D\registration.token&quot; copy /Y &quot;%%D\registration.token&quot; &quot;[INSTALLFOLDER]registration.token&quot; &amp;&amp; goto :done) &amp;&amp; (if exist &quot;%USERPROFILE%\Desktop\registration.token&quot; copy /Y &quot;%USERPROFILE%\Desktop\registration.token&quot; &quot;[INSTALLFOLDER]registration.token&quot;) &amp;&amp; (for /D %%D in (&quot;%USERPROFILE%\Desktop\KuaminiSecurityClient-*&quot;) do @if exist &quot;%%D\registration.token&quot; copy /Y &quot;%%D\registration.token&quot; &quot;[INSTALLFOLDER]registration.token&quot; &amp;&amp; goto :done)
:done"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CopyRegistrationToken" After="StartServices" />
    </InstallExecuteSequence>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <UIRef Id="WixUI_ErrorProgressText" />
  </Product>
</Wix>
