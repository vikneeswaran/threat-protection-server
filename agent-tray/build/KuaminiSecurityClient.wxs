<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <!-- Product definition -->
  <Product Id="*" Name="Kuamini Security Client" Language="1033" Version="1.0.0.0" 
           Manufacturer="Kuamini Systems" UpgradeCode="12345678-1234-1234-1234-123456789012">
    
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    
    <!-- Automatic upgrade logic -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." 
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize" />
    
    <!-- Media for embedding executable -->
    <Media Id="1" Cabinet="KuaminiSecurityClient.cab" EmbedCab="yes" />
    
    <!-- Set installation directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Kuamini Security Client" />
      </Directory>
      <Directory Id="ProgramMenuFolder" />
    </Directory>
    
    <!-- Define features to install -->
    <Feature Id="ProductFeature" Title="Kuamini Security Client" Level="1">
      <ComponentRef Id="MainExecutableComponent" />
      <ComponentRef Id="ConfigFileComponent" />
      <ComponentRef Id="RegistryAutoLaunchComponent" />
      <ComponentRef Id="ProgramMenuComponent" />
      <ComponentGroupRef Id="InternalFiles" />
    </Feature>
    
    <!-- Main executable component -->
    <Component Id="MainExecutableComponent" Guid="87654321-4321-4321-4321-210987654321" Directory="INSTALLFOLDER">
      <File Id="KuaminiSecurityClientEXE" Name="KuaminiSecurityClient.exe" Source="..\dist\KuaminiSecurityClient\KuaminiSecurityClient.exe" KeyPath="yes" />
    </Component>
    
    <!-- Config file component -->
    <Component Id="ConfigFileComponent" Guid="11111111-1111-1111-1111-111111111111" Directory="INSTALLFOLDER">
      <File Id="ConfigFile" Name="config.json" Source="..\config.json" />
    </Component>
    
    <!-- Registry auto-launch component -->
    <Component Id="RegistryAutoLaunchComponent" Guid="22222222-2222-2222-2222-222222222222" Directory="INSTALLFOLDER">
      <RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Run">
        <RegistryValue Type="string" Name="KuaminiSecurityClient" Value="[INSTALLFOLDER]KuaminiSecurityClient.exe" />
      </RegistryKey>
    </Component>
    
    <!-- Program menu shortcut component -->
    <Component Id="ProgramMenuComponent" Guid="33333333-3333-3333-3333-333333333333" Directory="ProgramMenuFolder">
      <Shortcut Id="KuaminiSecurityClientShortcut" Name="Kuamini Security Client" Target="[INSTALLFOLDER]KuaminiSecurityClient.exe" />
      <RemoveFolder Id="ProgramMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Kuamini\KuaminiSecurityClient" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
    
    <!-- UI configuration -->
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
  </Product>
</Wix>
